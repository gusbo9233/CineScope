@page
@model CineScope.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Signing in";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <p>Redirecting to Microsoft sign-in...</p>
                    <p class="text-muted">If you are not redirected, use this link:</p>
                    <a class="btn btn-primary" href="/MicrosoftIdentity/Account/SignIn?returnUrl=%2F">Sign In with Microsoft</a>
                </div>
            </div>
        </div>
    </div>
</div>
