@page
@model CineScope.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h3 class="mb-0">Access denied</h3>
                </div>
                <div class="card-body">
                    <p class="mb-3">
                        You are signed in, but your account does not have permission to use this part of CineScope.
                    </p>
                    <p class="text-muted mb-4">
                        Ask an administrator to assign you the required Member or Admin role.
                    </p>
                    <a href="/" class="btn btn-primary">Go to Home</a>
                    <a asp-page="/Account/Profile" class="btn btn-outline-secondary ms-2">View Profile</a>
                </div>
            </div>
        </div>
    </div>
</div>
