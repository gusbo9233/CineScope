@page
@using CineScope.Pages.Admin
@model DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">Admin Dashboard</h3>
                </div>
                <div class="card-body">
                    <p class="lead">Welcome, <strong>@User.Identity.Name</strong>! You have administrator access.</p>
                    
                    <div class="row mt-4">
                        <div class="col-md-4">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h5 class="card-title">Users</h5>
                                    <p class="card-text">Manage user roles and permissions</p>
                                    <a href="#" class="btn btn-primary btn-sm">View Users</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h5 class="card-title">Content</h5>
                                    <p class="card-text">Moderate and manage movies</p>
                                    <a href="#" class="btn btn-primary btn-sm">Manage Content</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h5 class="card-title">Analytics</h5>
                                    <p class="card-text">View system statistics</p>
                                    <a href="#" class="btn btn-primary btn-sm">View Analytics</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr />
                    
                    <h5>System Information</h5>
                    <table class="table table-sm">
                        <tbody>
                            <tr>
                                <td><strong>Environment:</strong></td>
                                <td>@(Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") ?? "Development")</td>
                            </tr>
                            <tr>
                                <td><strong>Machine Name:</strong></td>
                                <td>@Environment.MachineName</td>
                            </tr>
                            <tr>
                                <td><strong>Server Time:</strong></td>
                                <td>@DateTime.UtcNow:F (UTC)</td>
                            </tr>
                        </tbody>
                    </table>

                    <a href="/" class="btn btn-secondary">Back to Home</a>
                </div>
            </div>
        </div>
    </div>
</div>
