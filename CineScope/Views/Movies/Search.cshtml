@{
    ViewData["Title"] = "Search Movies";
}

<div class="cinema-page compact-page">
    <section class="search-hero">
        <p class="eyebrow">OMDb discovery</p>
        <h1>Find the next title for your collection.</h1>
        <p>Search by movie title, review the results, and import the best match into CineScope.</p>

        <form method="post" action="@Url.Action("SearchMovies")" class="spotlight-search">
            <input type="text" name="searchQuery" placeholder="Search for movies..." required />
            <button type="submit">Search</button>
        </form>

        @if (ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
        {
            <div class="cinema-alert cinema-alert-danger" role="alert">
                @Html.ValidationSummary(true)
            </div>
        }
    </section>
</div>
