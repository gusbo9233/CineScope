@model CineScope.Models.MovieModel

@{
    ViewData["Title"] = $"{Model.Title} - Movie Details";

    var averageRatingView = ViewData["AverageRating"] as decimal?;
    var ratingCount = ViewData["RatingCount"] as int? ?? 0;
    var userRating = ViewData["UserRating"] as int?;
    var isFavorite = ViewData["IsFavorite"] as bool? ?? false;

    // effectiveRating is null when there is no meaningful average (unrated).
    // Prefer the server-provided average when present; otherwise only fall back to the stored Model.Rating
    // if there are ratings recorded and the stored rating is non-zero.
    var effectiveRating = averageRatingView.HasValue
        ? averageRatingView
        : (ratingCount > 0 && Model.Rating > 0 ? (decimal?)Model.Rating : null);
    var ratingScale = (effectiveRating.HasValue && effectiveRating.Value > 5m) ? 10m : 5m;
    var ratingPercent = (!effectiveRating.HasValue || ratingCount == 0)
        ? 0
        : Math.Clamp((double)(effectiveRating.Value / ratingScale) * 100, 0, 100);
}

<div class="cinema-page compact-page">
    <a asp-controller="Movies" asp-action="Index" class="back-link">Back to Movies</a>

    <section class="details-showcase">
        <div class="details-poster">
            @if (!string.IsNullOrWhiteSpace(Model.PosterUrl) && Model.PosterUrl != "N/A")
            {
                <img src="@Model.PosterUrl" alt="@Model.Title poster" />
            }
            else
            {
                <div class="poster-placeholder poster-placeholder-large">@Model.Title</div>
            }
        </div>

        <div class="details-copy">
            <p class="eyebrow">Now viewing</p>
            <h1>@Model.Title</h1>
            <div class="hero-meta">
                <span>@Model.ReleaseYear</span>
                <span>@Model.Duration min</span>
                <span>@Model.Genre</span>
            </div>

            <div class="rating-panel" aria-label="Movie rating">
                <div>
                    <span>Audience score</span>
                    @if (ratingCount == 0 || !effectiveRating.HasValue)
                    {
                        <strong>Unrated</strong>
                    }
                    else
                    {
                        <strong>@effectiveRating.Value.ToString("0.0") / @ratingScale.ToString("0")</strong>
                    }
                </div>
                <div class="progress-track">
                    <div class="progress-fill" style="width: @ratingPercent%"></div>
                </div>
            </div>

            @if (User?.Identity?.IsAuthenticated == true)
            {
                <div class="user-rating">
                    <form asp-action="Rate" method="post" class="rating-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div>
                            <label>Your rating:</label>
                            <div class="star-options">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <label>
                                        <input type="radio" name="stars" value="@i" class="form-check-input" @(userRating.HasValue && userRating.Value == i ? "checked" : "") />
                                        @i ★
                                    </label>
                                }
                            </div>
                        </div>
                        <button type="submit" class="btn-cinema btn-cinema-primary">Save Rating</button>
                    </form>
                </div>
            }
            else
            {
                <p class="small text-muted">Sign in to rate this movie.</p>
            }

            <p class="details-description">@(string.IsNullOrWhiteSpace(Model.Description) ? "No synopsis available." : Model.Description)</p>

            <div class="hero-actions">
                @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                {
                    <a asp-controller="Movies" asp-action="Edit" asp-route-id="@Model.Id" class="btn-cinema btn-cinema-primary">Edit Movie</a>
                    <a asp-controller="Movies" asp-action="Delete" asp-route-id="@Model.Id" class="btn-cinema btn-cinema-danger">Delete Movie</a>
                }
                <a asp-controller="Movies" asp-action="Index" class="btn-cinema btn-cinema-secondary">Back to Library</a>

                @* Favorite heart button for signed-in members *@
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <form id="favorite-form" asp-controller="Movies" asp-action="ToggleFavorite" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" id="favorite-btn" class="btn-cinema btn-favorite" aria-pressed="@(isFavorite.ToString().ToLower())" title="Add to favorites">
                            <span id="favorite-icon" class="@(isFavorite ? "heart-filled" : "heart-outline")">❤</span>
                            <span id="favorite-text">@((isFavorite) ? "Favorited" : "Add to favorites")</span>
                        </button>
                    </form>
                }
            </div>
        </div>
    </section>

    <section class="details-grid" aria-label="Movie information">
        <article class="info-panel">
            <span>Movie ID</span>
            <strong>@Model.Id</strong>
        </article>
        <article class="info-panel">
            <span>IMDb ID</span>
            <strong>@(string.IsNullOrWhiteSpace(Model.ImdbId) ? "Not linked" : Model.ImdbId)</strong>
        </article>
        <article class="info-panel">
            <span>Release Year</span>
            <strong>@Model.ReleaseYear</strong>
        </article>
        <article class="info-panel">
            <span>Collection Age</span>
            <strong>@(DateTime.Now.Year - Model.ReleaseYear) years</strong>
        </article>
    </section>

    <section class="comments-section" aria-label="Comments">
        <h2>Comments</h2>

        <div id="comments-container">
            @Html.Partial("_Comments", Model.Comments)
        </div>

        <div class="comment-form mt-3">
            @if (User?.Identity?.IsAuthenticated == true)
            {
                <form id="comment-form" asp-action="AddComment" method="post" class="needs-validation">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="movieId" value="@Model.Id" />
                    <div class="mb-2">
                        <label for="content" class="form-label">Add a comment</label>
                        <textarea id="content" name="content" class="form-control" rows="4" required></textarea>
                    </div>
                    <button type="submit" class="btn-cinema btn-cinema-primary">Post Comment</button>
                </form>
            }
            else
            {
                <p class="small text-muted">
                    <a href="/MicrosoftIdentity/Account/SignIn?returnUrl=/Movies/Details/@Model.Id">Sign in</a> to post a comment.
                </p>
            }
        </div>
    </section>
</div>

@section Scripts {
    <script>
        (function () {
            // Comment form AJAX (existing)
            const commentForm = document.getElementById('comment-form');
            if (commentForm) {
                commentForm.addEventListener('submit', async function (e) {
                    e.preventDefault();
                    const submitBtn = commentForm.querySelector('button[type="submit"]');
                    submitBtn.disabled = true;

                    const formData = new FormData(commentForm);

                    try {
                        const response = await fetch(commentForm.action, {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            credentials: 'same-origin'
                        });

                        if (!response.ok) {
                            commentForm.submit();
                            return;
                        }

                        const html = await response.text();
                        const container = document.getElementById('comments-container');
                        if (container) {
                            container.innerHTML = html;
                        }

                        const textarea = commentForm.querySelector('textarea[name="content"]');
                        if (textarea) textarea.value = '';

                    } catch (err) {
                        commentForm.submit();
                    } finally {
                        submitBtn.disabled = false;
                    }
                });
            }

            // Favorite toggle AJAX
            const favForm = document.getElementById('favorite-form');
            if (favForm) {
                favForm.addEventListener('submit', async function (e) {
                    e.preventDefault();
                    const btn = document.getElementById('favorite-btn');
                    if (!btn) return;
                    btn.disabled = true;

                    const formData = new FormData(favForm);
                    const tokenInput = favForm.querySelector('input[name="__RequestVerificationToken"]');
                    const token = tokenInput ? tokenInput.value : null;

                    try {
                        const response = await fetch(favForm.action, {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest',
                                'RequestVerificationToken': token
                            },
                            credentials: 'same-origin'
                        });

                        if (!response.ok) {
                            // if unauthorized, redirect to sign-in
                            if (response.status === 401) {
                                window.location.href = "/MicrosoftIdentity/Account/SignIn?returnUrl=" + encodeURIComponent(window.location.pathname);
                                return;
                            }
                            // fallback to full submit if something went wrong
                            favForm.submit();
                            return;
                        }

                        const json = await response.json();
                        const favorited = json.favorited === true;

                        const icon = document.getElementById('favorite-icon');
                        const text = document.getElementById('favorite-text');

                        if (icon) {
                            icon.className = favorited ? 'heart-filled' : 'heart-outline';
                        }
                        if (text) {
                            text.textContent = favorited ? 'Favorited' : 'Add to favorites';
                        }
                        btn.setAttribute('aria-pressed', favorited.toString());
                    } catch (err) {
                        favForm.submit();
                    } finally {
                        btn.disabled = false;
                    }
                });
            }
        })();
    </script>
}
