@model List<CineScope.Models.MovieModel>
@{
    ViewData["Title"] = "Search Results";
    var movies = Model ?? new List<CineScope.Models.MovieModel>();
}

<div class="cinema-page">
    <section class="cinema-toolbar search-results-header" aria-label="Search results">
        <div>
            <p class="eyebrow">OMDb results</p>
            <h1>Results for "@ViewData["SearchQuery"]"</h1>
        </div>
        <a href="@Url.Action("Search")" class="btn-cinema btn-cinema-secondary">New Search</a>
    </section>

    @if (movies.Count == 0)
    {
        <section class="empty-state">
            <p class="eyebrow">No matches</p>
            <h2>Try a different title.</h2>
            <p>OMDb did not return movies for this search term.</p>
        </section>
    }
    else
    {
        <section class="movie-grid movie-grid-wide" aria-label="Search result movie cards">
            @foreach (var movie in movies)
            {
                <article class="movie-card result-card">
                    <div class="poster-link">
                        @if (!string.IsNullOrWhiteSpace(movie.PosterUrl) && movie.PosterUrl != "N/A")
                        {
                            <img src="@movie.PosterUrl" alt="@movie.Title poster" loading="lazy" />
                        }
                        else
                        {
                            <div class="poster-placeholder">@movie.Title</div>
                        }
                    </div>
                    <div class="movie-card-body">
                        <div class="movie-card-title">
                            <h3>@movie.Title</h3>
                            <span>@movie.Rating.ToString("0.0")</span>
                        </div>
                        <p>@movie.ReleaseYear | @movie.Duration min</p>
                        <p class="movie-genre">@movie.Genre</p>
                        <p class="movie-description">@(string.IsNullOrWhiteSpace(movie.Description) ? "No synopsis available." : movie.Description)</p>
                        <div class="movie-card-actions">
                            @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                            {
                                <form method="post" action="@Url.Action("ImportMovie")">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="imdbId" value="@movie.ImdbId" />
                                    <button type="submit">Import to DB</button>
                                </form>
                            }
                            else if (User?.Identity?.IsAuthenticated == true)
                            {
                                <a asp-page="/Account/AccessDenied">Import requires admin</a>
                            }
                            else
                            {
                                <a href="/MicrosoftIdentity/Account/SignIn?returnUrl=%2FMovies%2FSearch">Sign in to import</a>
                            }
                        </div>
                    </div>
                </article>
            }
        </section>
    }
</div>
