@model CineScope.Models.MovieModel

@{
    ViewData["Title"] = "Edit Movie";
}

<div class="cinema-page compact-page">
    <a asp-controller="Movies" asp-action="Details" asp-route-id="@Model.Id" class="back-link">Back to Details</a>

    <section class="form-shell">
        <div class="form-heading">
            <p class="eyebrow">Admin edit</p>
            <h1>Edit Movie</h1>
            <p>Update the title metadata, poster, and synopsis shown across CineScope.</p>
        </div>

        <form asp-action="Edit" method="post" class="cinema-form">
            @if (ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
            {
                <div class="cinema-alert cinema-alert-danger" role="alert">
                    <strong>Validation error</strong>
                    <ul>
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }

            <input type="hidden" asp-for="Id" />

            <div class="form-field">
                <label asp-for="Title"></label>
                <input type="text" asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="field-error"></span>
            </div>

            <div class="form-row">
                <div class="form-field">
                    <label asp-for="Genre"></label>
                    <select asp-for="Genre" class="form-select">
                        <option value="">Select a Genre</option>
                        <option value="Sci-Fi">Sci-Fi</option>
                        <option value="Drama">Drama</option>
                        <option value="Adventure">Adventure</option>
                        <option value="Comedy">Comedy</option>
                        <option value="Horror">Horror</option>
                        <option value="Thriller">Thriller</option>
                        <option value="Action">Action</option>
                        <option value="Romance">Romance</option>
                    </select>
                    <span asp-validation-for="Genre" class="field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="ReleaseYear"></label>
                    <input type="number" asp-for="ReleaseYear" class="form-control" min="1888" max="2100" />
                    <span asp-validation-for="ReleaseYear" class="field-error"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-field">
                    <label asp-for="Rating"></label>
                    <input type="number" asp-for="Rating" class="form-control" min="0" max="10" step="0.1" />
                    <span asp-validation-for="Rating" class="field-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Duration"></label>
                    <input type="number" asp-for="Duration" class="form-control" min="1" placeholder="Minutes" />
                    <span asp-validation-for="Duration" class="field-error"></span>
                </div>
            </div>

            <div class="form-field">
                <label asp-for="PosterUrl"></label>
                <input type="url" asp-for="PosterUrl" class="form-control" />
                <span asp-validation-for="PosterUrl" class="field-error"></span>
                @if (!string.IsNullOrWhiteSpace(Model.PosterUrl) && Model.PosterUrl != "N/A")
                {
                    <div class="poster-preview">
                        <img src="@Model.PosterUrl" alt="Poster preview" />
                    </div>
                }
            </div>

            <div class="form-field">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="field-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-cinema btn-cinema-primary">Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn-cinema btn-cinema-secondary">Cancel</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
