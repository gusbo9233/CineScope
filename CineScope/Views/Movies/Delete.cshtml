@model CineScope.Models.MovieModel

@{
    ViewData["Title"] = "Delete Movie";
}

<link rel="stylesheet" href="~/css/movies.css" />

<nav class="navbar">
    <div class="logo">Cine<span>Scope</span></div>

    <ul class="nav-links">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="Movies" asp-action="Index" class="active">Movies</a></li>
        <li><a asp-controller="Genres" asp-action="Index">Genres</a></li>
        <li><a asp-controller="Home" asp-action="About">About</a></li>
        <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
    </ul>

    <div class="nav-actions">
        <div class="notification">
            <span class="bell">🔔</span>
            <span class="badge">3</span>
        </div>

        <div class="profile">👤 Admin ▾</div>
    </div>
</nav>

<main class="page">
    <section class="card delete-card">
        <div class="delete-breadcrumb">
            <a asp-controller="Movies" asp-action="Details" asp-route-id="@Model.Id">← Back to Details</a>
        </div>

        <div class="delete-header">
            <h1>Delete Movie</h1>
            <p class="delete-warning">⚠️ Warning: This action cannot be undone.</p>
        </div>

        <hr class="section-divider" />

        <div class="delete-content">
            <p>Are you sure you want to delete the following movie?</p>

            <div class="movie-summary">
                <img src="@Model.PosterUrl" alt="@Model.Title poster" class="summary-poster" />
                
                <div class="summary-info">
                    <h2>@Model.Title</h2>
                    
                    <dl class="summary-details">
                        <dt>Genre:</dt>
                        <dd>@Model.Genre</dd>

                        <dt>Release Year:</dt>
                        <dd>@Model.ReleaseYear</dd>

                        <dt>Rating:</dt>
                        <dd>@Model.Rating / 5.0</dd>

                        <dt>Duration:</dt>
                        <dd>@Model.Duration minutes</dd>
                    </dl>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="summary-description">
                    <h3>Description</h3>
                    <p>@Model.Description</p>
                </div>
            }
        </div>

        <hr class="section-divider" />

        <div class="delete-actions">
            <form asp-action="Delete" method="post" style="display: inline;">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn-danger" onclick="return confirm('This will permanently delete this movie. Continue?')">🗑 Confirm Delete</button>
            </form>

            <a asp-action="Details" asp-route-id="@Model.Id" class="btn-secondary">Cancel</a>
        </div>
    </section>
</main>