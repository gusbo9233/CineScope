@model CineScope.Models.MovieModel

@{
    ViewData["Title"] = "Delete Movie";
}

<div class="cinema-page compact-page">
    <a asp-controller="Movies" asp-action="Details" asp-route-id="@Model.Id" class="back-link">Back to Details</a>

    <section class="delete-shell">
        <div class="form-heading">
            <p class="eyebrow">Confirm removal</p>
            <h1>Delete Movie</h1>
            <p>This permanently removes the title from your CineScope database.</p>
        </div>

        <div class="delete-summary">
            @if (!string.IsNullOrWhiteSpace(Model.PosterUrl) && Model.PosterUrl != "N/A")
            {
                <img src="@Model.PosterUrl" alt="@Model.Title poster" />
            }
            else
            {
                <div class="poster-placeholder">@Model.Title</div>
            }

            <div>
                <h2>@Model.Title</h2>
                <dl>
                    <dt>Genre</dt>
                    <dd>@Model.Genre</dd>
                    <dt>Release Year</dt>
                    <dd>@Model.ReleaseYear</dd>
                    <dt>Rating</dt>
                    <dd>@Model.Rating.ToString("0.0")</dd>
                    <dt>Duration</dt>
                    <dd>@Model.Duration minutes</dd>
                </dl>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="details-description">@Model.Description</p>
        }

        <div class="form-actions">
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn-cinema btn-cinema-danger" onclick="return confirm('This will permanently delete this movie. Continue?')">Confirm Delete</button>
            </form>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn-cinema btn-cinema-secondary">Cancel</a>
        </div>
    </section>
</div>
