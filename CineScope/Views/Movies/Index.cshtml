@model List<CineScope.Models.MovieModel>

@{
    ViewData["Title"] = "Manage Movies";
}

<link rel="stylesheet" href="~/css/movies.css" />

<nav class="navbar">
    <div class="logo">Cine<span>Scope</span></div>

    <ul class="nav-links">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="Movies" asp-action="Index" class="active">Movies</a></li>
        <li><a asp-controller="Genres" asp-action="Index">Genres</a></li>
        <li><a asp-controller="Home" asp-action="About">About</a></li>
        <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
    </ul>

    <div class="nav-actions">
        <div class="notification">
            <span class="bell">🔔</span>
            <span class="badge">3</span>
        </div>

        <div class="profile">👤 Admin ▾</div>
    </div>
</nav>

<main class="page">
    <section class="card">
        <div class="card-header">
            <div>
                <h1>Manage Movies</h1>
                <p>View, search and manage all movies in the system.</p>
            </div>

            <a asp-controller="Movies" asp-action="Create" class="add-btn">
                + Add New Movie
            </a>
        </div>

        <hr />

        <div class="toolbar">
            <div class="filters">
                <form asp-controller="Movies" asp-action="Index" method="get" class="search-box">
                    <span>🔍</span>
                    <input type="text" name="search" placeholder="Search by title..." />
                </form>

                <select name="genre">
                    <option value="">All Genres</option>
                    <option value="Sci-Fi">Sci-Fi</option>
                    <option value="Drama">Drama</option>
                    <option value="Adventure">Adventure</option>
                </select>
            </div>

            <div class="results">
                <span>Showing @Model.Count of @Model.Count movies</span>
                <button type="button" class="refresh-btn">⟳</button>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Genre</th>
                    <th>Rating</th>
                    <th>Release Date</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var movie in Model)
                {
                    <tr>
                        <td>@movie.Id</td>
                        <td>
                            <div class="movie">
                                <img src="@movie.PosterUrl" alt="@movie.Title poster" />
                                <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id">@movie.Title</a>
                            </div>
                        </td>
                        <td>@movie.Genre</td>
                        <td><span class="star">★</span> @movie.Rating</td>
                        <td>@movie.ReleaseYear</td>
                        <td>
                            <div class="actions">
                                <a asp-controller="Movies" asp-action="Edit" asp-route-id="@movie.Id" class="edit">✎ Edit</a>
                                <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id" class="details">◉ Details</a>
                                <a asp-controller="Movies" asp-action="Delete" asp-route-id="@movie.Id" class="delete">🗑 Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="table-footer">
            <p>Showing 1 to @Model.Count of @Model.Count entries</p>

            <div class="pagination">
                <button type="button">‹</button>
                <button type="button" class="current">1</button>
                <button type="button">›</button>
            </div>
        </div>

        <form asp-action="SeedPopularMovies" method="post" style="display: inline;">
            <button type="submit" class="add-btn">📥 Load Top 10 Movies</button>
        </form>
    </section>
</main> 