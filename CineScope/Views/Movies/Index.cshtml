@model List<CineScope.Models.MovieModel>

@{
    ViewData["Title"] = "Movies";
    var movies = Model ?? new List<CineScope.Models.MovieModel>();
    var heroMovie = movies.OrderByDescending(movie => movie.Rating).FirstOrDefault();
    var overallAvg = ViewData["OverallAverageRating"] as decimal?;
    var totalRatings = ViewData["TotalRatingCount"] as int? ?? 0;
    var averageRating = overallAvg ?? 0m;
    var totalRuntime = movies.Sum(movie => movie.Duration);
    var genres = movies
        .SelectMany(movie => (movie.Genre ?? string.Empty).Split(',', StringSplitOptions.RemoveEmptyEntries))
        .Select(genre => genre.Trim())
        .Where(genre => !string.IsNullOrWhiteSpace(genre))
        .Distinct()
        .Take(6)
        .ToList();
}

<div class="cinema-page">
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="cinema-alert cinema-alert-success" role="alert">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="cinema-alert cinema-alert-danger" role="alert">@errorMessage</div>
    }

    @if (TempData["InfoMessage"] is string infoMessage)
    {
        <div class="cinema-alert cinema-alert-info" role="alert">@infoMessage</div>
    }

    <section class="hero-banner" aria-label="CineScope movie dashboard">
        <div class="hero-copy">
            <p class="eyebrow">CineScope originals</p>
            <h1>@(heroMovie?.Title ?? "Build your movie universe")</h1>
            <p class="hero-description">
                @(heroMovie?.Description ?? "Search OMDb, import films, and manage your collection from one cinematic workspace.")
            </p>
            <div class="hero-meta">
                <span>@(heroMovie?.ReleaseYear.ToString() ?? "Curated")</span>
                <span>@(heroMovie?.Genre ?? "Movie library")</span>
                <span>
                    @if (heroMovie == null)
                    {
                        @("Ready to import")
                    }
                    else if (heroMovie.Rating == 0)
                    {
                        @("Unrated")
                    }
                    else
                    {
                        @(string.Format("{0:0.0} rating", heroMovie.Rating))
                    }
                </span>
            </div>
            <div class="hero-actions">
                @if (heroMovie != null)
                {
                    <a asp-controller="Movies" asp-action="Details" asp-route-id="@heroMovie.Id" class="btn-cinema btn-cinema-primary">View Feature</a>
                }
                <a asp-controller="Movies" asp-action="Search" class="btn-cinema btn-cinema-secondary">Search OMDb</a>
                @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Dashboard" class="btn-cinema btn-cinema-ghost">Admin Panel</a>
                }
            </div>
        </div>

        <div class="hero-art" aria-hidden="true">
            @if (!string.IsNullOrWhiteSpace(heroMovie?.PosterUrl) && heroMovie.PosterUrl != "N/A")
            {
                <img src="@heroMovie.PosterUrl" alt="" />
            }
            else
            {
                <div class="poster-placeholder poster-placeholder-large">CineScope</div>
            }
        </div>
    </section>

    <section class="metric-strip" aria-label="Collection overview">
        <div class="metric-card">
            <span>Total Movies</span>
            <strong>@movies.Count</strong>
            <small>In your library</small>
        </div>
        <div class="metric-card">
            <span>Avg Rating</span>
            @if (totalRatings == 0)
            {
                <strong>Unrated</strong>
            }
            else
            {
                <strong>@averageRating.ToString("0.0")</strong>
            }
            <small>Across all titles</small>        
        </div>
        <div class="metric-card">
            <span>Runtime</span>
            <strong>@totalRuntime</strong>
            <small>Total minutes</small>
        </div>
        <div class="metric-card" id="genresCard" role="button" tabindex="0" aria-controls="genreRow" aria-expanded="true">
            <span>Genres</span>
            <strong>@genres.Count</strong>
            <small>Top categories</small>
        </div>
    </section>

    <section class="cinema-toolbar" aria-label="Movie actions">
        <div>
            <p class="eyebrow">Browse</p>
            <h2>Movies</h2>
        </div>
        <div class="toolbar-actions">
            <a asp-controller="Movies" asp-action="Search" class="btn-cinema btn-cinema-secondary">Import Movie</a>
            <form asp-action="SeedPopularMovies" method="post">
                <button type="submit" class="btn-cinema btn-cinema-primary">Load Top 10</button>
            </form>
        </div>
    </section>

    @if (genres.Count > 0)
    {
        <div class="genre-row" id="genreRow" aria-label="Available genres">
            @foreach (var genre in genres)
            {
                <button type="button" class="genre-pill" data-genre="@genre">@genre</button>
            }
        </div>
    }

    <script>
        (function(){
            var genresCard = document.getElementById('genresCard');
            var genreRow = document.getElementById('genreRow');
            var pills = genreRow ? genreRow.querySelectorAll('.genre-pill') : [];
            var activeGenre = null;

            function setActivePill(pill){
                pills.forEach(function(p){ p.classList.remove('active'); });
                if(pill){ pill.classList.add('active'); }
            }

            function filterMoviesByGenre(genre){
                var cards = document.querySelectorAll('.movie-card');
                cards.forEach(function(card){
                    var genreText = (card.querySelector('.movie-genre') || { textContent: '' }).textContent || '';
                    if(!genre || genre === ''){
                        card.style.display = '';
                        return;
                    }
                    var genres = genreText.split(',').map(function(g){ return g.trim().toLowerCase(); });
                    if(genres.indexOf(genre.toLowerCase()) !== -1){
                        card.style.display = '';
                    } else {
                        card.style.display = 'none';
                    }
                });
            }

            // Toggle visibility of genre row when clicking the metric card
            if(genresCard && genreRow){
                genresCard.addEventListener('click', function(){
                    var expanded = genresCard.getAttribute('aria-expanded') === 'true';
                    genresCard.setAttribute('aria-expanded', (!expanded).toString());
                    if(expanded){
                        genreRow.style.display = 'none';
                    } else {
                        genreRow.style.display = '';
                    }
                });
                genresCard.addEventListener('keydown', function(e){
                    if(e.key === 'Enter' || e.key === ' '){
                        e.preventDefault();
                        genresCard.click();
                    }
                });
            }

            // Hook up pills
            Array.prototype.forEach.call(pills, function(pill){
                pill.addEventListener('click', function(){
                    var genre = pill.getAttribute('data-genre');
                    if(activeGenre === genre){
                        // clear filter
                        activeGenre = null;
                        setActivePill(null);
                        filterMoviesByGenre(null);
                    } else {
                        activeGenre = genre;
                        setActivePill(pill);
                        filterMoviesByGenre(genre);
                    }
                });
            });
        })();
    </script>

    @if (movies.Count == 0)
    {
        <section class="empty-state">
            <p class="eyebrow">No titles yet</p>
            <h2>Your screen is ready.</h2>
            <p>Import a movie from OMDb or load a starter set of top-rated films.</p>
            <div class="hero-actions">
                <a asp-controller="Movies" asp-action="Search" class="btn-cinema btn-cinema-secondary">Search OMDb</a>
                <form asp-action="SeedPopularMovies" method="post">
                    <button type="submit" class="btn-cinema btn-cinema-primary">Load Top 10</button>
                </form>
            </div>
        </section>
    }
    else
    {
        <section class="movie-grid" aria-label="Movie cards">
            @foreach (var movie in movies)
            {
                <article class="movie-card">
                    <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id" class="poster-link" aria-label="Open details for @movie.Title">
                        @if (!string.IsNullOrWhiteSpace(movie.PosterUrl) && movie.PosterUrl != "N/A")
                        {
                            <img src="@movie.PosterUrl" alt="@movie.Title poster" loading="lazy" />
                        }
                        else
                        {
                            <div class="poster-placeholder">@movie.Title</div>
                        }
                    </a>
                    <div class="movie-card-body">
                        <div class="movie-card-title">
                            <h3>@movie.Title</h3>
                            <span>
                                @if (movie.Rating == 0)
                                {
                                    @("Unrated")
                                }
                                else
                                {
                                    @(movie.Rating.ToString("0.0"))
                                }
                            </span>
                        </div>
                        <p>@movie.ReleaseYear | @movie.Duration min</p>
                        <p class="movie-genre">@movie.Genre</p>
                        <div class="movie-card-actions">
                            <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id">Details</a>
                            @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                            {
                                <a asp-controller="Movies" asp-action="Edit" asp-route-id="@movie.Id">Edit</a>
                                <a asp-controller="Movies" asp-action="Delete" asp-route-id="@movie.Id" class="danger-link">Delete</a>
                            }
                        </div>
                    </div>
                </article>
            }
        </section>
    }
</div>
