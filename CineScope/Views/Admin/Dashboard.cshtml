@model CineScope.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    var topMovie = Model.Movies.OrderByDescending(movie => movie.Rating).FirstOrDefault();
    var genreGroups = Model.Movies
        .SelectMany(movie => (movie.Genre ?? string.Empty).Split(',', StringSplitOptions.RemoveEmptyEntries))
        .Select(genre => genre.Trim())
        .Where(genre => !string.IsNullOrWhiteSpace(genre))
        .GroupBy(genre => genre)
        .OrderByDescending(group => group.Count())
        .Take(5)
        .ToList();
    var maxGenreCount = genreGroups.Count == 0 ? 1 : genreGroups.Max(group => group.Count());
}

<div class="admin-dashboard">
    <aside class="admin-sidebar" aria-label="Admin navigation">
        <div class="admin-sidebar-title">Admin Panel</div>
        <a asp-controller="Admin" asp-action="Dashboard" class="active">Overview</a>
        <a asp-controller="Movies" asp-action="Index">Movies</a>
        <a asp-controller="Movies" asp-action="Search">Import</a>
        <a asp-controller="Home" asp-action="Index">Platform</a>
    </aside>

    <div class="admin-content">
        <section class="admin-hero">
            <div>
                <p class="eyebrow">Admin analytics</p>
                <h1>CineScope Command Center</h1>
                <p>Signed in as @User.Identity?.Name. Monitor the library and edit database rows without leaving the dashboard.</p>
            </div>
            <div class="admin-hero-actions">
                <a asp-controller="Movies" asp-action="Index" class="btn-cinema btn-cinema-secondary">View Platform</a>
                <a asp-controller="Movies" asp-action="Search" class="btn-cinema btn-cinema-primary">Import Movie</a>
            </div>
        </section>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="cinema-alert cinema-alert-success" role="alert">@successMessage</div>
        }

        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="cinema-alert cinema-alert-danger" role="alert">@errorMessage</div>
        }

        <section class="admin-stats" aria-label="Database summary">
            <article class="admin-stat">
                <span>Total Movies</span>
                <strong>@Model.MovieCount</strong>
                <small>Rows in database</small>
            </article>
            <article class="admin-stat">
                <span>Avg Rating</span>
                @if ((ViewData["TotalRatingCount"] as int?) == 0)
                {
                    <strong>Unrated</strong>
                }
                else
                {
                    <strong>@Model.AverageRating.ToString("0.0")</strong>
                }
                <small>Across all titles</small>
            </article>
            <article class="admin-stat">
                <span>Total Runtime</span>
                <strong>@Model.TotalRuntime</strong>
                <small>Minutes indexed</small>
            </article>
            <article class="admin-stat highlight">
                <span>Top Rated</span>
                <strong>@(topMovie?.Title ?? "No titles")</strong>
                <small>@(topMovie == null ? "Import a movie" : $"{topMovie.Rating:0.0} rating")</small>
            </article>
        </section>

        <section class="admin-analytics-grid" aria-label="Admin analytics">
            <article class="admin-panel">
                <div class="panel-heading">
                    <h2>Library Health</h2>
                    <span>Live database snapshot</span>
                </div>
                <div class="admin-health">
                    <div>
                        <span>Editable rows</span>
                        <strong>@Model.MovieCount</strong>
                    </div>
                    <div>
                        <span>Linked IMDb IDs</span>
                        <strong>@Model.Movies.Count(movie => !string.IsNullOrWhiteSpace(movie.ImdbId))</strong>
                    </div>
                    <div>
                        <span>Poster coverage</span>
                        <strong>@Model.Movies.Count(movie => !string.IsNullOrWhiteSpace(movie.PosterUrl) && movie.PosterUrl != "N/A")</strong>
                    </div>
                </div>
            </article>

            <article class="admin-panel">
                <div class="panel-heading">
                    <h2>Top Genres</h2>
                    <span>Current collection mix</span>
                </div>
                @if (genreGroups.Count == 0)
                {
                    <p class="admin-muted">No genres found yet.</p>
                }
                else
                {
                    <div class="genre-bars">
                        @foreach (var genre in genreGroups)
                        {
                            var percent = Math.Max(12, genre.Count() * 100 / maxGenreCount);
                            <div class="genre-bar">
                                <div>
                                    <span>@genre.Key</span>
                                    <strong>@genre.Count()</strong>
                                </div>
                                <div class="bar-track">
                                    <span style="width: @percent%"></span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </article>
        </section>

        <!-- Movie Database panel removed per request. Movie management is available via Movies controller routes. -->
    </div>
</div>

@section Scripts {
    <!-- No dashboard table scripts required after removal -->
}
