<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CineScope</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/movies.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CineScope.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg app-nav" aria-label="Primary navigation">
            <div class="container-fluid app-nav-inner">
                <a class="navbar-brand brand-mark" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-play"></span>
                    <span>Cine<span>Scope</span></span>
                </a>
                <button class="navbar-toggler app-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation" aria-controls="mainNavigation"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavigation">
                    <ul class="navbar-nav app-links me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Movies</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Movies" asp-action="Index">Browse</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Movies" asp-action="Search">Search OMDb</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link admin-nav-link" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a>
                        </li>
                    </ul>
                    <form class="app-search" method="post" asp-controller="Movies" asp-action="SearchMovies" role="search">
                        <input type="search" name="searchQuery" class="form-control" placeholder="Search titles" aria-label="Search movies" />
                        <button type="submit">Search</button>
                    </form>
                    <ul class="navbar-nav app-account">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle account-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end app-dropdown" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" asp-page="/Account/Profile">Profile</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-page="/Account/Signout">Sign Out</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link account-link" asp-page="/Account/Login">Sign In</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="app-shell">
        <main role="main" class="app-main">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container-fluid">
            <span>&copy; 2026 CineScope</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
